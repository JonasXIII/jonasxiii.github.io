// firestore.rules - paste this into Firebase Console -> Firestore Database ->
// Rules, replacing whatever's there. (No Firebase CLI needed to apply this -
// the console's rules editor works fine for a project this size.)
//
// Collection/decks/binders/boxes are readable by anyone (showcase-style, like
// the rest of the site), but writes require being signed in as the owner -
// this is the real enforcement; the client-side isOwner() check in auth.js
// just avoids a confusing failed write for anyone who isn't you.
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid}/{document=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
